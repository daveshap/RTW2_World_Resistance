    },
    {
      "effect_key": "rom_tech_military_management_unit_cost_mod",
      "reason": "Duplicates the chosen canonical recruitment-cost metric and would make the cap opaque."
    },
    {
      "effect_key": "rom_force_unit_mod_experience_base_infantry",
      "reason": "Would double-stack with generic recruit rank for infantry."
