{
  "schema_version": 1,
  "title": "WR2 World Resistance effect-bundle matrix",
  "advancement_stage": "start_turn_completed",
  "bundle_target": "faction",
  "application_contract": {
    "eligibility": "every active non-human faction",
    "war_or_relationship_filter": false,
    "base_bundle_mode": "exactly_one_exclusive_absolute_tier",
    "catchup_bundle_mode": "zero_or_one_exclusive_absolute_level",
    "zero_value_rows": "omit",
    "base_bundle_keys": [
      "wr2_wr_ai_tier_00",
      "wr2_wr_ai_tier_20",
      "wr2_wr_ai_tier_40",
      "wr2_wr_ai_tier_65",
      "wr2_wr_ai_tier_85",
      "wr2_wr_ai_tier_100"
    ],
    "base_pressure_thresholds": [0, 20, 40, 65, 85, 100],
    "catchup_bundle_keys": [
      "wr2_wr_ai_catchup_1",
      "wr2_wr_ai_catchup_2",
      "wr2_wr_ai_catchup_3"
    ]
  },
  "safety_caps": {
