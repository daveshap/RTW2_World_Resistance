    "construction_turns_removed": -7,
    "recruit_rank": 9,
    "army_armour_points": 10,
    "army_morale_points": 10,
    "army_melee_damage_percent": 10,
    "experience_gain_percent": 15,
    "replenishment_percentage_points": 50,
    "rule": "Catch-up bundles contain no construction, recruitment, upkeep, or mercenary cost reducers, so this mod's own base-plus-catch-up stack cannot exceed the cost ceiling."
